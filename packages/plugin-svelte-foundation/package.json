{
  "name": "@nexus-mindgarden/plugin-svelte-foundation",
  "version": "0.6.0",
  "description": "Plugin-UI Foundation — Svelte 5 Custom-Elements + Theme-Attribut + 16-Token-Convention + Bundle-Pipeline",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "default": "./dist/theme/index.js"
    },
    "./build": {
      "types": "./dist/build/index.d.ts",
      "default": "./dist/build/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MrDewitt88/plugin-template.git",
    "directory": "packages/plugin-svelte-foundation"
  },
  "homepage": "https://github.com/MrDewitt88/plugin-template/tree/main/packages/plugin-svelte-foundation#readme",
  "bugs": {
    "url": "https://github.com/MrDewitt88/plugin-template/issues"
  },
  "keywords": ["nexus-mindgarden", "plugin", "svelte", "custom-elements", "theme"],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
