{
  "name": "@nexus-mindgarden/plugin-template",
  "version": "0.6.0",
  "description": "Cross-Repo Plugin Template — TeamMind/Nexus Plugin-Provider Foundation",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "pnpm -r build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "pnpm -r build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MrDewitt88/plugin-template.git"
  }
}
