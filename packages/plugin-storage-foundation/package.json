{
  "name": "@nexus-mindgarden/plugin-storage-foundation",
  "version": "0.7.0",
  "description": "Plugin-Storage Foundation — SQLite-Setup + Migrations + Multi-Host-Storage-Pattern + ABI-Cache-Awareness",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./sqlite": {
      "types": "./dist/sqlite/index.d.ts",
      "default": "./dist/sqlite/index.js"
    },
    "./fs": {
      "types": "./dist/fs/index.d.ts",
      "default": "./dist/fs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MrDewitt88/plugin-template.git",
    "directory": "packages/plugin-storage-foundation"
  },
  "homepage": "https://github.com/MrDewitt88/plugin-template/tree/main/packages/plugin-storage-foundation#readme",
  "bugs": {
    "url": "https://github.com/MrDewitt88/plugin-template/issues"
  },
  "keywords": ["nexus-mindgarden", "plugin", "storage", "sqlite", "migrations"],
  "dependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
