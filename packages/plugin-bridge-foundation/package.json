{
  "name": "@nexus-mindgarden/plugin-bridge-foundation",
  "version": "0.5.0",
  "description": "Plugin-Bridge HTTP-Server Foundation — handshake/manifest/health/execute-tool/render-ui Endpoints + JWT-Auth + Multi-Host-Registry + manifest_hash",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "default": "./dist/auth/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest/index.d.ts",
      "default": "./dist/manifest/index.js"
    },
    "./observability": {
      "types": "./dist/observability/index.d.ts",
      "default": "./dist/observability/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    },
    "./agent-complete": {
      "types": "./dist/agent-complete/index.d.ts",
      "default": "./dist/agent-complete/index.js"
    },
    "./shapes": {
      "types": "./dist/shapes/index.d.ts",
      "default": "./dist/shapes/index.js"
    },
    "./persona": {
      "types": "./dist/persona/index.d.ts",
      "default": "./dist/persona/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MrDewitt88/plugin-template.git",
    "directory": "packages/plugin-bridge-foundation"
  },
  "homepage": "https://github.com/MrDewitt88/plugin-template/tree/main/packages/plugin-bridge-foundation#readme",
  "bugs": {
    "url": "https://github.com/MrDewitt88/plugin-template/issues"
  },
  "keywords": ["nexus-mindgarden", "plugin", "bridge", "hono", "jwt", "mcp"],
  "dependencies": {
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "better-sqlite3": "^11.10.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
