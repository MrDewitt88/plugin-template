node_modules/
# Note: NO global `dist/` rule — Foundation-packages ship pre-built dist/ in
# git as bridge to npm-publish (v0.3.3+). Consumer github-installs without
# `&path:` subspec already get prepare-hook rebuild; with `&path:` they need
# committed dist as fallback (pnpm doesn't run sub-package prepare hooks).
# Per-package consumer-side builds via tsc remain functional (dist/ overwritten).
# Workspace-internal: build via `pnpm -r build`, output goes to packages/*/dist/.
# Note: NO global `build/` rule — that pattern unintentionally excluded
# `packages/plugin-svelte-foundation/src/build/` (legitimate source folder).
# If you need to ignore a per-package build-output, add a per-package
# `.gitignore` or use a more specific pattern.
.turbo/
.cache/
*.tsbuildinfo

# Test
coverage/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Env / Secrets
.env
.env.local
.env.*.local
*.key
*.pem
*.p12
*.pfx
*.crt

# Plugin-Template runtime artefacts (per-plugin generated)
storage/
plugins/

# Claude Code + chatbus per-session state (user/machine-specific paths,
# never sharable). .claude/settings.local.json.suggested is the EXCEPTION
# — that file is committed as Convention-Seed (siehe docs/templates/
# CLAUDE-SETTINGS-LOCAL-TEMPLATE.md).
.chatbus
.claude/scheduled_tasks.lock
.claude/settings.json
.claude/settings.local.json
.mcp.json
