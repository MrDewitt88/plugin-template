{
  "name": "@nexus-mindgarden/granite-test",
  "version": "0.0.4",
  "description": "Granite-Floor test-coverage framework — plugin-author-declared MCP-tool test-suites + chatbus-event reporter for Oracle's @floor aggregator. v0.0.4: CRITICAL FIX — reporter chatbus-wire-shape (to_role→to + add group:mindgarden). v0.0.3 silently 0-emitted; v0.0.4 fixes the adoption-wave bug.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./reporter": {
      "types": "./dist/reporter.d.ts",
      "default": "./dist/reporter.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./prompt-builder": {
      "types": "./dist/prompt-builder.d.ts",
      "default": "./dist/prompt-builder.js"
    }
  },
  "bin": {
    "granite-test": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MrDewitt88/plugin-template.git",
    "directory": "packages/granite-test"
  },
  "homepage": "https://github.com/MrDewitt88/plugin-template/tree/main/packages/granite-test#readme",
  "bugs": {
    "url": "https://github.com/MrDewitt88/plugin-template/issues"
  },
  "keywords": [
    "nexus-mindgarden",
    "granite",
    "granite-floor",
    "llm-testing",
    "mcp",
    "tool-coverage",
    "ci"
  ],
  "peerDependencies": {
    "@nexus-mindgarden/plugin-bridge-foundation": "^0.6.1"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
